<odoo>
    <record id="group_intern_bridge_student" model="res.groups">
        <field name="name">InternBridge Student</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_intern_bridge_mentor" model="res.groups">
        <field name="name">InternBridge Company Mentor</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_intern_bridge_guide" model="res.groups">
        <field name="name">InternBridge College Guide</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_intern_bridge_admin" model="res.groups">
        <field name="name">InternBridge Admin</field>
        <field name="implied_ids" eval="[(4, ref('base.group_system'))]"/>
    </record>


</odoo>