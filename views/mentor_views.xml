<odoo>
   <record id="view_mentor_tree" model="ir.ui.view">
        <field name="name">intern.bridge.mentor.tree</field>
        <field name="model">intern.bridge.mentor</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="email"/>
                <field name="user_id"/>
            </tree>
        </field>
    </record>
    <record id="view_mentor_form" model="ir.ui.view">
        <field name="name">intern.bridge.mentor.form</field>
        <field name="model">intern.bridge.mentor</field>
        <field name="arch" type="xml">
            <form string="Mentor">
                <sheet>
                    <header>
                        <button name="action_create_user"
                            string="Create User"
                            type="object"
                            class="btn-primary"/>
                    </header>
                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="user_password" password="True"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mentor" model="ir.actions.act_window">
        <field name="name">Mentor</field>
        <field name="res_model">intern.bridge.mentor</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>