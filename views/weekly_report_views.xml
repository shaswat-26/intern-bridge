<odoo>
    <record id="view_weekly_report_tree" model="ir.ui.view">
        <field name="name">weekly.report.tree</field>
        <field name="model">intern.bridge.weekly.report</field>
        <field name="arch" type="xml">
            <tree>
                <field name="internship_id"/>
                <field name="student_id"/>
                <field name="company_id"/>
                <field name="week_number"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="view_weekly_report_form" model="ir.ui.view">
        <field name="name">weekly.report.form</field>
        <field name="model">intern.bridge.weekly.report</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="internship_id"/>
                        <field name="student_id"/>
                    </group>

                    <group>
                        <field name="company_id" readonly="1"/>
                        <field name="mentor_id" readonly="1"/>
                    </group>

                    <group>
                        <field name="start_date" readonly="1"/>
                        <field name="end_date" readonly="1"/>
                        <field name="week_number"/>
                        <field name="report_date"/>
                    </group>

                    <group>
                        <field name="work_done"/>
                        <field name="challenges"/>
                        <field name="learning"/>
                        <field name="hours_worked"/>
                    </group>

                    <group>
                        <field name="mentor_feedback"/>
                        <field name="guide_feedback"/>
                        <field name="status" widget="statusbar"
                               statusbar_visible="draft,submitted,mentor_review,approved"/>
                    </group>

                    <group>
                        <button name="action_submit" type="object" string="Submit"/>
                        <button name="action_mentor_review" type="object" string="Mentor Review"/>
                        <button name="action_approve" type="object" string="Approve"/>
                        <button name="action_print_pdf" type="object" string="Print PDF" class="btn-primary"/>
                    </group>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>

                </sheet>
            </form>
        </field>
    </record>
     <record id="view_monthly_report_graph_state" model="ir.ui.view">
        <field name="name">monthly.report.graph.state</field>
        <field name="model">intern.bridge.monthly.report</field>
         <field name="groups_id" eval="[
        (4, ref('base.group_system')),
        (4, ref('intern_bridge.group_intern_bridge_mentor')),
        (4, ref('intern_bridge.group_intern_bridge_guide'))
    ]"/>
        <field name="arch" type="xml">
            <graph string="Report Status" type="pie">
                <field name="state"/>
                <field name="student_id"/>
                <field name="id" type="measure"/>
            </graph>
        </field>
    </record>
    <record id="view_weekly_report_graph_hours" model="ir.ui.view">
        <field name="name">weekly.report.graph.hours</field>
        <field name="model">intern.bridge.weekly.report</field>
        <field name="groups_id" eval="[
        (4, ref('base.group_system')),
        (4, ref('intern_bridge.group_intern_bridge_mentor')),
        (4, ref('intern_bridge.group_intern_bridge_guide'))
    ]"/>
        <field name="arch" type="xml">
            <graph string="Hours Worked per Week" type="bar">
                <field name="week_number"/>
                <field name="student_id"/>
                <field name="hours_worked" type="measure"/>
            </graph>
        </field>
    </record>
    <record id="view_weekly_report_graph_status" model="ir.ui.view">
        <field name="name">weekly.report.graph.status</field>
        <field name="model">intern.bridge.weekly.report</field>
        <field name="groups_id" eval="[
        (4, ref('base.group_system')),
        (4, ref('intern_bridge.group_intern_bridge_mentor')),
        (4, ref('intern_bridge.group_intern_bridge_guide'))
    ]"/>
        <field name="arch" type="xml">
            <graph string="Report Status" type="pie">
                <field name="status"/>
                <field name="student_id"/>
                <field name="id" type="measure"/>
            </graph>
        </field>
    </record>
    <record id="action_weekly_reports" model="ir.actions.act_window">
        <field name="name">Weekly Reports</field>
        <field name="res_model">intern.bridge.weekly.report</field>
        <field name="view_mode">tree,form,graph</field>
    </record>
</odoo>